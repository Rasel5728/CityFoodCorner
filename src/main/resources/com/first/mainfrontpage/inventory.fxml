<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="550.0" prefWidth="716.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.first.mainfrontpage.InventoryController">
   <children>
      <AnchorPane layoutX="0.0" layoutY="0.0" prefHeight="550.0" prefWidth="716.0"
                  AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                  AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>

            <!-- TABLE -->
            <AnchorPane layoutX="12.0" layoutY="9.0" prefHeight="283.0" prefWidth="691.0"
                        styleClass="shadow" stylesheets="@../Alpha/inventoryDesign.css">
               <children>
                  <TableView fx:id="inventory_tableView" layoutX="8.0" layoutY="9.0"
                             prefHeight="266.0" prefWidth="674.0" tableMenuButtonVisible="true">
                     <columns>
                        <TableColumn fx:id="inventory_col_productID"   prefWidth="75.0"  text="Product ID" />
                        <TableColumn fx:id="inventory_col_productName" prefWidth="100.0" text="Product Name" />
                        <TableColumn fx:id="inventory_col_type"        prefWidth="100.0" text="Type" />
                        <TableColumn fx:id="inventory_col_stock"       prefWidth="100.0" text="Stock" />
                        <TableColumn fx:id="inventory_col_price"       prefWidth="100.0" text="Price" />
                        <TableColumn fx:id="inventory_col_status"      prefWidth="100.0" text="Status" />
                        <TableColumn fx:id="inventory_col_date"        prefWidth="100.0" text="Date" />
                     </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                  </TableView>
               </children>
            </AnchorPane>

            <!-- FORM -->
            <AnchorPane fx:id="inventory_form" layoutX="13.0" layoutY="312.0"
                        prefHeight="228.0" prefWidth="691.0"
                        styleClass="shadow" stylesheets="@../Alpha/inventoryDesign.css">
               <children>

                  <Label layoutX="40.0" layoutY="36.0" text="Product ID:">
                     <font><Font size="15.0" /></font>
                  </Label>
                  <TextField fx:id="inventory_productID" layoutX="121.0" layoutY="34.0"
                             prefHeight="26.0" prefWidth="118.0" />

                  <Label layoutX="14.0" layoutY="73.0" text="Product Name:">
                     <font><Font size="15.0" /></font>
                  </Label>
                  <TextField fx:id="inventory_productName" layoutX="121.0" layoutY="71.0"
                             prefHeight="26.0" prefWidth="156.0" />

                  <Label layoutX="78.0" layoutY="111.0" text="Type:">
                     <font><Font size="15.0" /></font>
                  </Label>
                  <ComboBox fx:id="inventory_type" layoutX="121.0" layoutY="109.0"
                            prefHeight="26.0" prefWidth="156.0" promptText="Choose Type..." />

                  <Label layoutX="312.0" layoutY="36.0" text="Stock:">
                     <font><Font size="15.0" /></font>
                  </Label>
                  <TextField fx:id="inventory_stock" layoutX="358.0" layoutY="33.0"
                             prefHeight="26.0" prefWidth="156.0" promptText="0" />

                  <Label layoutX="316.0" layoutY="73.0" text="Price:">
                     <font><Font size="15.0" /></font>
                  </Label>
                  <TextField fx:id="inventory_price" layoutX="358.0" layoutY="71.0"
                             prefHeight="26.0" prefWidth="156.0" promptText="0.0" />

                  <Label layoutX="308.0" layoutY="111.0" text="Status:">
                     <font><Font size="15.0" /></font>
                  </Label>
                  <ComboBox fx:id="inventory_status" layoutX="358.0" layoutY="108.0"
                            prefHeight="26.0" prefWidth="156.0" promptText="Choose Status..." />

                  <!-- Image Box -->
                  <AnchorPane layoutX="550.0" layoutY="11.0" prefHeight="146.0" prefWidth="130.0"
                              styleClass="shadow" stylesheets="@../Alpha/inventoryDesign.css">
                     <children>
                        <ImageView fx:id="inventory_imageView"
                                   layoutX="5.0" layoutY="5.0"
                                   fitHeight="136.0" fitWidth="120.0"
                                   preserveRatio="true" />
                     </children>
                  </AnchorPane>

                  <!-- Buttons -->
                  <Button fx:id="inventory_addBtn" layoutX="97.0" layoutY="175.0"
                          text="Add" onAction="#inventoryAddBtn"
                          prefHeight="36.0" prefWidth="84.0"
                          style="-fx-background-radius: 8;"
                          styleClass="btn" stylesheets="@../Alpha/inventoryDesign.css" />

                  <Button fx:id="inventory_updateBtn" layoutX="194.0" layoutY="175.0"
                          text="Update" onAction="#inventoryUpdateBtn"
                          prefHeight="36.0" prefWidth="84.0"
                          style="-fx-background-radius: 8;"
                          styleClass="btn" stylesheets="@../Alpha/inventoryDesign.css" />

                  <Button fx:id="inventory_clearBtn" layoutX="292.0" layoutY="175.0"
                          text="Clear" onAction="#inventoryClearBtn"
                          prefHeight="36.0" prefWidth="84.0"
                          style="-fx-background-radius: 8;"
                          styleClass="btn" stylesheets="@../Alpha/inventoryDesign.css" />

                  <Button layoutX="392.0" layoutY="175.0"
                          text="Delete" onAction="#inventoryDeleteBtn"
                          prefHeight="36.0" prefWidth="84.0"
                          style="-fx-background-radius: 8;"
                          styleClass="btn" stylesheets="@../Alpha/inventoryDesign.css" />

                  <Button fx:id="inventory_importBtn" layoutX="578.0" layoutY="166.0"
                          text="Import" onAction="#inventoryImportBtn"
                          prefHeight="30.0" prefWidth="74.0"
                          style="-fx-background-radius: 8;"
                          styleClass="btn" stylesheets="@../Alpha/inventoryDesign.css" />

               </children>
            </AnchorPane>

            <Separator layoutX="14.0" layoutY="296.8" prefHeight="8.0" prefWidth="691.0"
                       AnchorPane.bottomAnchor="245.0" AnchorPane.leftAnchor="14.0"
                       AnchorPane.rightAnchor="11.0" AnchorPane.topAnchor="297.0" />

         </children>
      </AnchorPane>
   </children>
</AnchorPane>